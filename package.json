{
  "name": "personal-memory-mcp",
  "version": "0.1.0",
  "description": "Self-hosted Markdown-backed MCP memory server",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "check": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "stdio": "tsx src/stdio.ts",
    "client:create": "tsx src/scripts/create-client.ts",
    "reindex": "tsx src/scripts/reindex.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "@tailwindcss/postcss": "^4.3.0",
    "better-sqlite3": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "latest",
    "gray-matter": "latest",
    "lucide-react": "^1.16.0",
    "nanoid": "latest",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "tsx": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=20"
  }
